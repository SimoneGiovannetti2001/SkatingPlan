<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>


<AnchorPane prefHeight="720.0" prefWidth="1280.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.skatingplan.ControllerGrafici.DettagliPrenotazioneAtletaControllerG">
   <children>
      <ImageView fitHeight="720.0" fitWidth="1280.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../image/DettagliPrenotazione.jpg" />
         </image>
      </ImageView>
      <Button fx:id="confermaScelta" layoutX="414.0" layoutY="553.0" mnemonicParsing="false" onAction="#onConfermaSceltaClick" prefHeight="100.0" prefWidth="200.0" style="-fx-background-color: #38bdf8;" text="Conferma Scelta" textFill="#000066">
         <font>
            <Font size="20.0" />
         </font>
      </Button>
      <Button fx:id="tornaAllaScelta" layoutX="690.0" layoutY="553.0" mnemonicParsing="false" onAction="#onTornaAllaScelta" prefHeight="100.0" prefWidth="200.0" style="-fx-background-color: #38bdf8;" text="Torna alla scelta" textFill="#000066">
         <font>
            <Font size="20.0" />
         </font>
      </Button>
   </children>
</AnchorPane>
