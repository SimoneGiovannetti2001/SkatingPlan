<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="720.0" prefWidth="1280.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.skatingplan.ControllerGrafici.PrenotaAtletaControllerG">
   <children>
      <ImageView fitHeight="720.0" fitWidth="1280.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../image/AtletaPrenota.jpg" />
         </image>
      </ImageView>
      <Button fx:id="gestisciPrenotazioni" layoutX="1.0" layoutY="190.0" mnemonicParsing="false" onAction="#onGestisciPrenotazioniClick" opacity="0.0" prefHeight="123.0" prefWidth="168.0" />
      <Button fx:id="prenotaLezione" layoutY="69.0" mnemonicParsing="false" onAction="#onPrenotaLezioneClick" opacity="0.0" prefHeight="118.0" prefWidth="169.0" text="Button" />
      <Button fx:id="conferma" layoutX="598.0" layoutY="552.0" mnemonicParsing="false" onAction="#onConfermaClick" prefHeight="100.0" prefWidth="200.0" style="-fx-background-color: #38bdf8;" text="Conferma" textFill="#000066" />
   </children>
</AnchorPane>
