      <Button fx:id="prenotaLezione" alignment="BASELINE_LEFT" graphicTextGap="1.0" layoutY="80.0" mnemonicParsing="false" onAction="#onPrenotaLezioneClick" prefHeight="108.0" prefWidth="169.0" style="-fx-background-color: blank;" stylesheets="@../filecss/Button.css" text="Prenota&#10;lezione" textFill="#000066">
