            <Font size="22.0" />
         </font>
      </Button>
      <Button fx:id="conferma" layoutX="598.0" layoutY="552.0" mnemonicParsing="false" onAction="#onConfermaClick" prefHeight="100.0" prefWidth="200.0" style="-fx-background-color: #38bdf8;" text="Conferma" textFill="#000066">
