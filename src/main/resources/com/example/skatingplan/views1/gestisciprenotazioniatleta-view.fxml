      </ImageView>
      <Button fx:id="gestisciPrenotazioni" alignment="BASELINE_LEFT" contentDisplay="CENTER" layoutX="-1.0" layoutY="190.0" mnemonicParsing="false" onAction="#onGestisciPrenotazioniClick" prefHeight="108.0" prefWidth="170.0" style="-fx-background-color: #38bdf8;" stylesheets="@../filecss/Button.css" text="Gestisci&#10;prenotazione" textFill="#000066">
         <font>
            <Font size="22.0" />
